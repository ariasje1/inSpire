<% layout('layout/boilerplate')%>
<div id="cluster-map"></div>
<div class="container">
    <h1>All Climbing Routes</h1>
    <div>
        <a href="/climbRoutes/new">
            <button>Add Climbing Route</button>
        </a>
    </div>
   
<% for(let climbRoute of climbRoutes) { %>
    <div class="card mb-3">
        <div class="row">
            <div class="col-md-4">
                <% if(climbRoute.images.length > 0) { %>
                    <img src="<%= climbRoute.images[0].url %>" class="img-fluid" alt="">
                <% } else { %>
                    <img src="/images/default-route.jpg" class="img-fluid" alt="Default Climbing Route Image">
                <% } %>
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h5 class="card-title"> <%= climbRoute.title %> </h5>
                    <p class="card-text"><%= climbRoute.description %></p>
                    <p class="card-text"> 
                        <small class="text-muted"><%= climbRoute.location %></small>
                    </p>
                    <a class="btn btn-primary" href="/climbRoutes/<%= climbRoute._id %>">View <%= climbRoute.title %></a>
                </div>
            </div>
        </div>
    </div>
<% } %>
</div>
    
<script>
    const mapToken = '<%= process.env.MAPBOX_TOKEN %>';
    const climbRoutes = {
        type: 'FeatureCollection',
        features: <%- JSON.stringify(climbRoutes.map(c => ({
            type: 'Feature',
            geometry: c.geometry,
            properties: {
                popUpMarkup: `<a href="/climbRoutes/${c._id}">${c.title}</a>`
            }
        }))) %>
    };
</script>
<script src="/javascripts/clusterMap.js"></script>